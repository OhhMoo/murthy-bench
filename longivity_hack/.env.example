# Longevity-LLM Endpoint Configuration
# Copy this file to .env and fill in your actual values

# HuggingFace API Token (required for LongeBench dataset and L-LLM endpoint)
HF_TOKEN=hf_xxxxxxxxxxxxx

# L-LLM Endpoint (provided by hackathon organizers)
L_LLM_ENDPOINT=https://swchnq0ekc3scmqw.us-east-2.aws.endpoints.huggingface.cloud

# Other provider API keys (optional, depending on which models you test)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
